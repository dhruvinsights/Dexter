# Dexter Frontend Environment Configuration
# Copy this file to `.env` (gitignored) and customize as needed

# ============================================================================
# AI Backend Configuration (Optional)
# ============================================================================
# The frontend can connect to an optional AI/RAG backend for policy analysis,
# summaries, and conversational assistance. If not set, defaults to Render.
#
# Primary AI backend URL (defaults to Render if not set)
# VITE_AI_API_URL=https://dexter-space.onrender.com
#
# Fallback AI backend URL (defaults to Railway if not set)
# VITE_AI_API_FALLBACK_URL=https://dexter-production-ff80.up.railway.app
#
# For local backend development, uncomment and use:
# VITE_AI_API_URL=http://localhost:8000
#
# Note: Users can also switch backends at runtime via the Settings panel.
# Environment variables set the initial defaults only.

# ============================================================================
# Space-Track.org Credentials (Optional)
# ============================================================================
# Required ONLY for `npm run fetch-fullcat` to fetch the full ~28k satellite
# catalogue. CelesTrak (`npm run fetch-tle`) needs no credentials.
# Register free at https://www.space-track.org
#
SPACETRACK_USER=you@example.com
SPACETRACK_PASS=your-password
